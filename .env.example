# ─── Required ──────────────────────────────────────────────────────────────────
# Get from https://my.telegram.org/apps
API_ID=12345678
API_HASH=your_api_hash_here

# Get from @BotFather on Telegram
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MongoDB connection string (leave empty to use in-memory mock DB for testing)
# Format: mongodb+srv://user:password@cluster.mongodb.net/
DATABASE_URI=
DATABASE_NAME=EvaMaria

# ─── Admin / Auth ──────────────────────────────────────────────────────────────
# Space-separated Telegram user IDs with full admin access
ADMINS=123456789

# Space-separated user IDs with elevated (non-owner) auth access
AUTH_USERS=

# Channel ID for subscription enforcement (0 = disabled)
# Users must join this channel to use the bot
AUTH_CHANNEL=0

# ─── Channel Indexing ──────────────────────────────────────────────────────────
# Space-separated channel IDs to auto-index media from
CHANNELS=-100xxxxxxxxxx

# ─── Bot Identity ──────────────────────────────────────────────────────────────
BOT_NAME=EvaMariaBot
BOT_USERNAME=YourBotUsername

# ─── Logging ───────────────────────────────────────────────────────────────────
# Channel ID where bot startup/error messages are sent
LOG_CHANNEL=0

# ─── Start Images (rotating) ───────────────────────────────────────────────────
# Space-separated image URLs shown in /start messages
START_IMG_URL=https://telegra.ph/file/example1.jpg https://telegra.ph/file/example2.jpg

# ─── Caption Templates ────────────────────────────────────────────────────────
# Available placeholders: {file_name}, {file_size}, {duration}
FILE_CAPTION={file_name}

📁 Size: {file_size}
🕒 Duration: {duration}

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Prevent forwarding of delivered files
PROTECT_CONTENT=false

# Reply with spelling suggestion if search returns no results
SPELL_CHECK_REPLY=false

# Maximum number of filters/results to list
MAX_LIST_ELM=50

# Send files to PM instead of in-group
PM_MODE=false

# Show only one result button per search
SINGLE_BUTTON=false

# ─── IMDb Template ───────────────────────────────────────────────────────────
IMDB_TEMPLATE=🎬 <b>{title}</b> ({year})
⭐ Rating: {rating} ({votes} votes)
🎭 Genre: {genres}
🎥 Director: {director}
👥 Cast: {cast}
📝 {plot}
